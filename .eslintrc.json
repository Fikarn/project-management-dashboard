{
  "extends": ["next/core-web-vitals", "prettier"],
  "overrides": [
    {
      "files": ["electron/**/*.ts"],
      "env": { "node": true, "browser": false },
      "parserOptions": {
        "project": "./electron/tsconfig.json"
      },
      "rules": {
        "@next/next/no-img-element": "off"
      }
    },
    {
      "files": ["scripts/**/*.ts"],
      "rules": {
        "@typescript-eslint/no-require-imports": "off"
      }
    }
  ]
}
