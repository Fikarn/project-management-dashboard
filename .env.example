# Native runtime overrides (optional).
# SSE_APP_DATA_DIR=/path/to/app-data
# SSE_LOG_DIR=/path/to/logs

# One-shot legacy import (reads an old Electron-era db.json on first native launch).
# SSE_LEGACY_DB_PATH=/path/to/db.json
# SSE_DISABLE_AUTO_IMPORT=1

# Qt Installer Framework tool overrides for local packaging runs.
# SSE_QT_IFW_BINARYCREATOR=/path/to/binarycreator
# SSE_QT_IFW_REPOGEN=/path/to/repogen
