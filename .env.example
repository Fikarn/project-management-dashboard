# Override the data directory (used by Electron to point at OS userData path).
# Defaults to ./data in the project root.
# DB_DIR=/path/to/data

# Sentry DSN for error tracking in production (optional — omit to disable entirely).
# Get a free DSN at https://sentry.io
# SENTRY_DSN=https://your-key@sentry.io/your-project-id

# Required for Sentry source map uploads in CI (optional).
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
